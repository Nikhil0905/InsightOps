# InsightOps — required environment variables
# Usage: source .env  (bash/zsh)
#
# Fill in your real values below, then run:
#   source .env
#   python ai-engine/main.py --dry-run

# Splunk REST API credentials (port 8089)
export SPLUNK_USERNAME=your_splunk_username
export SPLUNK_PASSWORD=your_splunk_password

# Splunk HTTP Event Collector token (port 8088)
export SPLUNK_HEC_TOKEN=your_hec_token_here
